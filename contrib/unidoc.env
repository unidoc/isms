# UniDoc ISMS environment
# Copy to ~/unidoc.env and set ISMS_ENV=~/unidoc.env
# chmod 600 ~/unidoc.env

# ─── Required ────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgres://localhost/unidoc-isms

# JWT signing secret (min 32 chars). Generate: openssl rand -hex 32
ISMS_SECRET=<generate-with-openssl-rand-hex-32>

# Storage backend: "file" (local disk) or "s3" (S3-compatible)
ISMS_STORAGE_BACKEND=file

# Data directory for repos and local file storage
ISMS_DATA_DIR=/home/ahall/isms/data

# ─── S3 storage (required if ISMS_STORAGE_BACKEND=s3) ───────────────

# ISMS_S3_BUCKET=isms-data
# ISMS_S3_REGION=auto
# ISMS_S3_ENDPOINT=https://xyz.r2.cloudflarestorage.com
# ISMS_S3_ACCESS_KEY=<access-key>
# ISMS_S3_SECRET_KEY=<secret-key>

# ─── Server ──────────────────────────────────────────────────────────

# Base URL (used for CORS, passkeys, notification links)
# ISMS_BASE_URL=https://isms.unidoc.io

# Vue web frontend dist directory
ISMS_WEB_DIR=/home/ahall/Projects/isms/web/dist

# ISMS repository root (where the git repo lives)
ISMS_ROOT=/home/ahall/Projects/unidoc-isms

# Organization UUID (from isms server org list)
ISMS_ORGANIZATION=<your-org-uuid>

# User identity for CLI actions
ISMS_USER=ahall@command.is

# ─── Auth ────────────────────────────────────────────────────────────

# Cloudflare Zero Trust (production)
# CLOUDFLARE_TEAM_DOMAIN=mycompany.cloudflareaccess.com

# Dev mode: self-signup and skip email verification
# ISMS_USER_SIGNUP=1
# ISMS_SKIP_EMAIL_VERIFY=1
# ISMS_RATE_LIMIT=0

# ─── SMTP (optional) ────────────────────────────────────────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=<smtp-password>
# SMTP_FROM=noreply@example.com

# ─── Notifications ──────────────────────────────────────────────────
# Slack and Matrix are configured per-org in Admin > Settings.
# No server-level env vars needed.

# ─── Git commit signing (optional) ──────────────────────────────────

# ISMS_SIGNING_KEY=/path/to/ssh-key
# ISMS_SIGNING_NAME=isms.sh
# ISMS_SIGNING_EMAIL=git@isms.sh

# ─── Platform branding (optional) ───────────────────────────────────

# ISMS_TERMS_FILE=/path/to/terms.md
# ISMS_PRIVACY_FILE=/path/to/privacy.md
# ISMS_HIDE_POWERED_BY=1
